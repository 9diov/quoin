{
  "name": "markdown-type-system",
  "version": "0.1.0",
  "description": "A type system for Markdown files that validates frontmatter properties against Markdown-defined schemas.",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/integration/node-cli/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "jsonc-parser": "^3.3.1",
    "mdast-util-from-markdown": "^2.0.3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  }
}
